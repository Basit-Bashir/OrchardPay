# --- Database ---
# Local dev uses SQLite. For production swap to Postgres, e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/hortitrack"
DATABASE_URL="file:./dev.db"

# --- Auth ---
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- SMS ---
# "console" logs messages to the server console (no account needed).
# "twilio" sends real SMS via Twilio.
SMS_PROVIDER="console"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- Email (optional) ---
RESEND_API_KEY=""
